   "source": [
    "import torch\n",
    "\n",
    "\n",
    "M = torch.rand((4, 3))\n",
    "k = 2\n",
    "Uk, sk, Vk = torch.svd_lowrank(M, q=k)\n",
    "approximated_M = torch.mm(torch.mm(Uk, torch.diag(sk)), Vk.t())\n",
    "print(M)\n",
    "print(approximated_M)"
   ]
  }
