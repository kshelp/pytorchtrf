   "source": [
    "import torch\n",
    "\n",
    "\n",
    "M = torch.rand((4, 3))\n",
    "U, s, V = torch.svd(M)\n",
    "composed_M = torch.mm(torch.mm(U, torch.diag(s)), V.t())\n",
    "print(M)\n",
    "print(composed_M)"
   ]
  }
