        "######################\n",
        "# 1. 자소 단위 토큰화\n",
        "from jamo import h2j, j2hcj\n",
        "\n",
        "review = \"현실과 구분 불가능한 cg. 시각적 즐거음은 최고! 더불어 ost는 더더욱 최고!!\"\n",
